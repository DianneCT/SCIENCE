<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>All 13 Cycles — Interactive Composite Wave</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --bg2: #f5f4f0;
    --bg3: #eeede8;
    --text: #1a1a18;
    --text2: #5f5e5a;
    --border: rgba(0,0,0,0.12);
    --radius: 8px;
    --coral: #F0997B;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1a18;
      --bg2: #242422;
      --bg3: #2e2e2b;
      --text: #f0ede6;
      --text2: #888780;
      --border: rgba(255,255,255,0.12);
    }
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 2rem 1.5rem;
    max-width: 960px;
    margin: 0 auto;
    line-height: 1.6;
  }

  h1 { font-size: 20px; font-weight: 500; margin-bottom: 4px; }
  .subtitle { font-size: 13px; color: var(--text2); margin-bottom: 1.5rem; max-width: 700px; }

  /* ── top controls ── */
  .controls-top {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 12px;
  }

  .tab-btn {
    font-size: 12px;
    padding: 5px 14px;
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: transparent;
    color: var(--text2);
    cursor: pointer;
    transition: background 0.15s;
  }
  .tab-btn:hover { background: var(--bg2); }
  .tab-btn.active {
    background: var(--bg3);
    color: var(--text);
    font-weight: 500;
  }

  .thresh-wrap {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text2);
  }
  .thresh-wrap input[type=range] { width: 90px; accent-color: var(--coral); }
  .thresh-wrap .tval { font-weight: 500; color: var(--text); min-width: 32px; }

  /* ── cycle toggles ── */
  .cycle-toggles {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    margin-bottom: 12px;
    font-size: 12px;
    color: var(--text2);
  }
  .cycle-toggles label {
    display: flex;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    user-select: none;
  }
  .cycle-toggles input[type=checkbox] { accent-color: var(--coral); width: 13px; height: 13px; }
  .dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }

  /* ── chart ── */
  .chart-wrap {
    position: relative;
    width: 100%;
    height: 420px;
    margin-bottom: 10px;
  }

  /* ── legend ── */
  .legend {
    display: flex;
    gap: 6px 18px;
    flex-wrap: wrap;
    margin: 8px 0 18px;
    font-size: 12px;
    color: var(--text2);
  }
  .li { display: flex; align-items: center; gap: 6px; }
  .ll { width: 22px; height: 2.5px; border-radius: 1px; flex-shrink: 0; }
  .ld { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  /* ── sliders ── */
  .sliders-section {
    border-top: 0.5px solid var(--border);
    padding-top: 14px;
  }
  .sliders-label {
    font-size: 11px;
    color: var(--text2);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }
  .slider-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 32px;
  }
  @media (max-width: 560px) { .slider-grid { grid-template-columns: 1fr; } }

  .sr {
    display: grid;
    grid-template-columns: 160px 1fr 32px;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
  }
  .sr label {
    font-size: 12px;
    color: var(--text2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .sr input[type=range] { accent-color: var(--coral); }
  .sr .val { font-size: 12px; font-weight: 500; color: var(--text); text-align: right; }

  footer {
    margin-top: 2.5rem;
    font-size: 11px;
    color: var(--text2);
    border-top: 0.5px solid var(--border);
    padding-top: 12px;
    line-height: 1.8;
  }
  footer a { color: var(--text2); }
</style>
</head>
<body>

<h1>Cycles within cycles — all 13, interactive</h1>
<p class="subtitle">Superposition of 13 nested cycles from 1 Hz to 225 million years (galactic year), on a logarithmic time axis. Toggle cycles on/off, adjust their amplitudes, switch between composite-only and individual+composite views, and set the interference threshold.</p>

<div class="controls-top">
  <button class="tab-btn active" id="btn-composite" onclick="setView('composite')">Composite only</button>
  <button class="tab-btn" id="btn-both" onclick="setView('both')">Individual + composite</button>
  <div class="thresh-wrap">
    <label for="tsl">Threshold</label>
    <input type="range" id="tsl" min="40" max="95" step="5" value="75" oninput="onThresh(this.value)">
    <span class="tval" id="tval">75%</span>
  </div>
</div>

<div class="cycle-toggles" id="cycle-toggles"></div>

<div class="chart-wrap">
  <canvas id="wc" role="img"
    aria-label="Interactive superposition of 13 nested cycles from 1 Hz to 225 million years on a logarithmic time axis, with composite wave and interference markers.">
    Superposition of 13 nested cycles — composite interference wave with constructive and destructive peaks marked.
  </canvas>
</div>

<div class="legend">
  <div class="li"><div class="ll" style="background:#F0997B;"></div>Composite wave</div>
  <div class="li"><div class="ld" style="background:#E24B4A;"></div>Constructive peak</div>
  <div class="li"><div class="ld" style="background:#378ADD;"></div>Destructive trough</div>
  <div class="li" style="margin-left:8px;opacity:0.6;font-style:italic;">Individual waves shown at 50% opacity in "Individual + composite" view</div>
</div>

<div class="sliders-section">
  <div class="sliders-label">Amplitude sliders</div>
  <div class="slider-grid" id="sliders"></div>
</div>

<footer>
  <strong>Cycles included:</strong>
  1 Hz &mdash;
  Tidal (~12.4 h, 2 highs + 2 lows per day) &mdash;
  Earth day (86,400 s) &mdash;
  Lunar month (29.53 days) &mdash;
  Season / 3-month cycle &mdash;
  Earth year (365.25 days) &mdash;
  Solar cycle (11 years) &mdash;
  Volcanic flare-up cycle (~100 years) &mdash;
  Earth crust–mantle magma cycle (~1,500 years) &mdash;
  Bray cycle (~2,400 years) &mdash;
  Sun–Sirius revolution about Alcyone / precession (~26,000 years) &mdash;
  Milankovitch orbital cycle (~100,000 years) &mdash;
  Galactic year / cosmic year (~225 million years).<br>
  Time axis is logarithmic (seconds). Interference markers appear at local peaks/troughs exceeding the
  threshold % of the maximum composite amplitude. Hover a marker to see its value.
  Built with <a href="https://www.chartjs.org/" target="_blank">Chart.js 4.4.1</a>.
</footer>

<script>
const CYCLES = [
  { label: "1 Hz",                   period_s: 1,                          color: "#E24B4A" },
  { label: "Tidal (~12 h)",          period_s: 12.4 * 3600,                color: "#D85A30" },
  { label: "Earth day",              period_s: 86400,                      color: "#BA7517" },
  { label: "Lunar month",            period_s: 29.53 * 86400,              color: "#639922" },
  { label: "Season (3 mo)",          period_s: 91.25 * 86400,              color: "#1D9E75" },
  { label: "Earth year",             period_s: 365.25 * 86400,             color: "#378ADD" },
  { label: "Solar cycle (11 yr)",    period_s: 11 * 365.25 * 86400,        color: "#7F77DD" },
  { label: "Volcanic (100 yr)",      period_s: 100 * 365.25 * 86400,       color: "#D4537E" },
  { label: "Magma (1,500 yr)",       period_s: 1500 * 365.25 * 86400,      color: "#888780" },
  { label: "Bray cycle (2,400 yr)",  period_s: 2400 * 365.25 * 86400,      color: "#EF9F27" },
  { label: "Precession (26k yr)",    period_s: 26000 * 365.25 * 86400,     color: "#5DCAA5" },
  { label: "Milankovitch (100k yr)", period_s: 1e5 * 365.25 * 86400,       color: "#AFA9EC" },
  { label: "Galactic year (225M yr)",period_s: 225e6 * 365.25 * 86400,     color: "#F09595" },
];

const amps    = CYCLES.map(() => 1.0);
const enabled = CYCLES.map(() => true);
let threshPct = 75;
let viewMode  = "composite";
let chartInst = null;
const N = 800;

/* ── x axis ── */
function buildXVals() {
  const active = CYCLES.filter((_, i) => enabled[i]);
  if (!active.length) return [];
  const periods = active.map(c => c.period_s);
  const logMin  = Math.log10(Math.min(...periods) * 0.05);
  const logMax  = Math.log10(Math.max(...periods) * 3.0);
  return Array.from({length: N}, (_, i) =>
    Math.pow(10, logMin + (logMax - logMin) * i / (N - 1)));
}

/* ── compute ── */
function computeWave(i, xVals) {
  return xVals.map(t => amps[i] * Math.sin(2 * Math.PI * t / CYCLES[i].period_s));
}

function computeComposite(xVals) {
  return xVals.map(t =>
    CYCLES.reduce((s, c, i) =>
      enabled[i] ? s + amps[i] * Math.sin(2 * Math.PI * t / c.period_s) : s, 0));
}

function findPeaks(composite, xVals) {
  const mx  = Math.max(...composite.map(Math.abs));
  const cut = (threshPct / 100) * mx;
  const constructive = [], destructive = [];
  for (let i = 1; i < composite.length - 1; i++) {
    const v = composite[i], p = composite[i-1], n = composite[i+1];
    if (Math.abs(v) >= cut) {
      if (v > 0 && v >= p && v >= n) constructive.push({x: xVals[i], y: v});
      if (v < 0 && v <= p && v <= n) destructive.push({x: xVals[i], y: v});
    }
  }
  return {constructive, destructive, mx};
}

/* ── tick labels ── */
function buildTickMap() {
  const m = {};
  CYCLES.forEach(c => {
    const lbl = c.label.replace(/ \(.*\)/, '').replace('~', '');
    m[c.period_s] = lbl;
  });
  return m;
}

/* ── chart ── */
function buildChart() {
  const xVals = buildXVals();
  if (!xVals.length) {
    if (chartInst) { chartInst.destroy(); chartInst = null; }
    return;
  }

  const composite = computeComposite(xVals);
  const {constructive, destructive, mx: compMax} = findPeaks(composite, xVals);
  const tickMap = buildTickMap();
  const activeCount = enabled.filter(Boolean).length;
  const yMax = Math.max(compMax, activeCount * 0.6) * 1.18;

  const datasets = [];

  /* individual waves (behind composite) */
  if (viewMode === 'both') {
    CYCLES.forEach((c, i) => {
      if (!enabled[i]) return;
      const wave = computeWave(i, xVals);
      datasets.push({
        label: c.label,
        data:  xVals.map((x, xi) => ({x, y: wave[xi]})),
        borderColor: c.color + '70',
        backgroundColor: 'transparent',
        borderWidth: 1.0,
        pointRadius: 0,
        tension: 0.2,
        order: 3,
      });
    });
  }

  /* composite wave */
  datasets.push({
    label: 'Composite',
    data:  xVals.map((x, i) => ({x, y: composite[i]})),
    borderColor: '#F0997B',
    backgroundColor: 'rgba(240,153,123,0.07)',
    fill: true,
    borderWidth: viewMode === 'both' ? 2.0 : 2.5,
    pointRadius: 0,
    tension: 0.25,
    order: 2,
  });

  /* interference markers */
  datasets.push({
    label: 'Constructive', type: 'scatter',
    data:  constructive.map(p => ({x: p.x, y: p.y})),
    borderColor: '#E24B4A', backgroundColor: '#E24B4A',
    pointRadius: viewMode === 'both' ? 5 : 6,
    pointStyle: 'circle', order: 1, showLine: false,
  });
  datasets.push({
    label: 'Destructive', type: 'scatter',
    data:  destructive.map(p => ({x: p.x, y: p.y})),
    borderColor: '#378ADD', backgroundColor: '#378ADD',
    pointRadius: viewMode === 'both' ? 5 : 6,
    pointStyle: 'circle', order: 1, showLine: false,
  });

  if (chartInst) chartInst.destroy();
  chartInst = new Chart(document.getElementById('wc'), {
    type: 'line',
    data: {datasets},
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      plugins: {
        legend: {display: false},
        tooltip: {
          filter: item =>
            item.dataset.label === 'Constructive' || item.dataset.label === 'Destructive',
          callbacks: {
            label: item =>
              `${item.dataset.label}: ${item.parsed.y.toFixed(2)}` +
              (compMax > 0
                ? ` (${(Math.abs(item.parsed.y) / compMax * 100).toFixed(0)}% of max)`
                : '')
          }
        }
      },
      scales: {
        x: {
          type: 'logarithmic',
          title: {
            display: true,
            text: 'Time (log scale, seconds)',
            font: {size: 11},
            color: '#888780'
          },
          ticks: {
            color: '#888780',
            font: {size: 9},
            maxTicksLimit: 16,
            callback(v) {
              const keys = Object.keys(tickMap).map(Number);
              const cl   = keys.reduce((a, b) =>
                Math.abs(b - v) < Math.abs(a - v) ? b : a);
              return Math.abs(cl - v) / v < 0.35 ? tickMap[cl] : '';
            }
          },
          grid: {color: 'rgba(128,128,120,0.09)'}
        },
        y: {
          min: -yMax, max: yMax,
          title: {
            display: true,
            text: 'Composite amplitude',
            font: {size: 11},
            color: '#888780'
          },
          ticks: {
            color: '#888780',
            font: {size: 9},
            maxTicksLimit: 7,
            callback: v => v.toFixed(1)
          },
          grid: {color: 'rgba(128,128,120,0.09)'},
          afterDataLimits(scale) { scale.max = yMax; scale.min = -yMax; }
        }
      },
      parsing: {xAxisKey: 'x', yAxisKey: 'y'}
    }
  });
}

/* ── cycle on/off toggles ── */
function buildToggles() {
  const cont = document.getElementById('cycle-toggles');
  cont.innerHTML = '';
  CYCLES.forEach((c, i) => {
    const lbl = document.createElement('label');
    lbl.innerHTML =
      `<input type="checkbox" checked onchange="onToggle(${i}, this.checked)">` +
      `<span class="dot" style="background:${c.color};"></span>` +
      `${c.label}`;
    cont.appendChild(lbl);
  });
}

function onToggle(i, checked) {
  enabled[i] = checked;
  buildChart();
}

/* ── amplitude sliders ── */
function buildSliders() {
  const cont = document.getElementById('sliders');
  cont.innerHTML = '';
  CYCLES.forEach((c, i) => {
    const row = document.createElement('div');
    row.className = 'sr';
    const vid = `av-${i}`;
    row.innerHTML =
      `<label title="${c.label}">` +
        `<span class="dot" style="background:${c.color};"></span>` +
        `${c.label}` +
      `</label>` +
      `<input type="range" min="0" max="2" step="0.05" value="1"` +
        ` oninput="onSlide(${i}, this.value, '${vid}')">` +
      `<span class="val" id="${vid}">1.0</span>`;
    cont.appendChild(row);
  });
}

function onSlide(i, v, vid) {
  amps[i] = parseFloat(v);
  document.getElementById(vid).textContent = parseFloat(v).toFixed(1);
  buildChart();
}

function onThresh(v) {
  threshPct = parseInt(v);
  document.getElementById('tval').textContent = v + '%';
  buildChart();
}

function setView(mode) {
  viewMode = mode;
  document.getElementById('btn-composite').classList.toggle('active', mode === 'composite');
  document.getElementById('btn-both').classList.toggle('active', mode === 'both');
  buildChart();
}

buildToggles();
buildSliders();
buildChart();
</script>
</body>
</html>
